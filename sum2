        $data = ["contents" => [["parts" => [["text" => $prompt]]]]];

        $ch = curl_init();
        curl_setopt($ch, CURLOPT_URL, "https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateContent?key=".$apiKey);
        curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
        curl_setopt($ch, CURLOPT_POST, true);
        curl_setopt($ch, CURLOPT_TIMEOUT, 200);
        curl_setopt($ch, CURLOPT_HTTPHEADER, ["Content-Type: application/json"]);
        curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode($data));

        $response = curl_exec($ch);

        if(curl_errno($ch)){
            $ai_output = "خطأ في الاتصال بالذكاء الاصطناعي: " . curl_error($ch);
        } else {
            $result = json_decode($response, true);
            $ai_output = $result['candidates'][0]['content']['parts'][0]['text'] ?? 
                         $result['candidates'][0]['content']['text'] ?? 
                         "فشل التلخيص";
            $ai_output = trim(preg_replace("/(\r?\n){2,}/", "\n\n", $ai_output));
        }
        curl_close($ch);
    }
